# if DOTFILES_ACTIVE_PROFILES array is not empty
if (( ${#DOTFILES_ACTIVE_PROFILES[@]} )); then
    for profile in "${DOTFILES_ACTIVE_PROFILES[@]}"; do
        echo "activated profile $profile"
        for file in $DOTFILES_ROOT_FOLDER/custom/profile/$profile/.*; do
            [ -r "$file" ] && [ -f "$file" ] && source "$file";
        done
    done
fi

unset file