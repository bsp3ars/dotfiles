# Used this site for conversion of original colors: https://hexdocs.pm/color_palette/ansi_color_codes.html

color_cyan='%F{14}'
color_magenta='%F{13}'
color_reset='%f'
color_white='%F{15}'

setopt prompt_subst

PS1='(${color_cyan}%m${color_reset})' # hostname
PS1+='[%~]' # directory
PS1+='$(git_branch)' # branch
PS1+='${color_magenta}%#${color_reset} '
export PS1